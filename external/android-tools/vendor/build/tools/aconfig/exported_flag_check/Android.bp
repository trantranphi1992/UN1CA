package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

rust_defaults {
    name: "exported-flag-check-defaults",
    edition: "2021",
    clippy_lints: "android",
    lints: "android",
    crate_root: "src/main.rs",
    srcs: [
        "non_api_flags_list.txt",
        "non_api_flags_packages.txt",
        "skip_api_filter_list.txt",
    ],
    rustlibs: [
        "libaconfig_protos",
        "libanyhow",
        "libclap",
        "libprotobuf",
        "libregex",
    ],
}

rust_binary_host {
    name: "exported-flag-check",
    defaults: ["exported-flag-check-defaults"],
}

rust_test_host {
    name: "exported-flag-check-test",
    defaults: ["exported-flag-check-defaults"],
    test_suites: ["general-tests"],
    srcs: [
        "tests/api-signature-file.txt",
        "tests/finalized-flags.txt",
        "tests/flags.textproto",
    ],
}
